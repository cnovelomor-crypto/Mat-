rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function emailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isParentOf(childData) {
      return isSignedIn() && childData.parentId == request.auth.uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Rules ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.get('role', '') in ['parent', 'child']
          && data.get('displayName', '') is string && data.get('displayName', '').size() <= 60
          && (data.get('role', '') == 'parent' ? data.get('uid', '') == request.auth.uid : (data.get('parentId', '') == request.auth.uid))
          && (data.keys().hasAll(['uid', 'role', 'displayName']) && data.keys().size() <= 8);
      }

      allow get: if isSignedIn() && (
        request.auth.uid == userId || 
        (exists(/databases/$(database)/documents/users/$(userId)) && get(/databases/$(database)/documents/users/$(userId)).data.get('parentId', '') == request.auth.uid)
      );
      
      allow list: if isSignedIn() && (
        resource.data.get('uid', '') == request.auth.uid || 
        resource.data.get('parentId', '') == request.auth.uid
      );
      
      allow create: if isSignedIn() && isValidUser(incoming()) && (request.auth.uid == userId || incoming().get('parentId', '') == request.auth.uid);
      
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && isValidUser(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'points', 'parentId', 'linkingCode', 'photoURL'])) ||
        (existing().get('parentId', '') == request.auth.uid && isValidUser(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['points', 'parentId', 'displayName', 'photoURL']))
      );
    }

    // --- Exercise Results ---
    match /exerciseResults/{resultId} {
      function isValidResult(data) {
        return data.get('childId', '') is string && isValidId(data.get('childId', ''))
          && data.get('category', '') in ['sumas', 'restas', 'multiplicaciones', 'divisiones', 'figuras']
          && data.get('score', 0) is int && data.get('score', 0) >= 0
          && data.get('starsEarned', 0) is int && data.get('starsEarned', 0) >= 0
          && data.get('timestamp', request.time) == request.time
          && data.keys().hasAll(['childId', 'category', 'score', 'totalQuestions', 'starsEarned', 'timestamp']);
      }

      function canAccessResult(childId) {
        return childId == request.auth.uid || 
          (exists(/databases/$(database)/documents/users/$(childId)) && 
           get(/databases/$(database)/documents/users/$(childId)).data.get('parentId', '') == request.auth.uid);
      }

      allow read: if isSignedIn() && canAccessResult(resource.data.get('childId', ''));
      allow create: if isSignedIn() && isValidResult(incoming()) && canAccessResult(incoming().get('childId', ''));
    }

    // --- Rewards ---
    match /rewards/{rewardId} {
      function isValidReward(data) {
        return data.get('title', '') is string && data.get('title', '').size() <= 100
          && data.get('cost', 0) is int && data.get('cost', 0) >= 0
          && data.get('icon', '') is string
          && (data.get('isCustom', false) == false || (data.get('parentId', '') == request.auth.uid))
          && data.keys().hasAll(['title', 'cost', 'icon']);
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidReward(incoming()) && (incoming().get('isCustom', false) == true ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'parent' : false);
      allow update, delete: if isSignedIn() && resource.data.get('parentId', '') == request.auth.uid;
    }

    // --- Redemptions ---
    match /redemptions/{redemptionId} {
      function isValidRedemption(data) {
        let childId = data.get('childId', '');
        let isChildOrParent = childId == request.auth.uid || 
          (exists(/databases/$(database)/documents/users/$(childId)) && 
           get(/databases/$(database)/documents/users/$(childId)).data.get('parentId', '') == request.auth.uid);

        return isChildOrParent
          && data.get('status', '') == 'pending'
          && data.get('timestamp', request.time) == request.time
          && data.get('parentId', '') is string
          && data.keys().hasAll(['childId', 'rewardId', 'rewardTitle', 'status', 'timestamp', 'parentId']);
      }

      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.get('childId', '') || 
        resource.data.get('parentId', '') == request.auth.uid
      );
      
      allow create: if isSignedIn() && isValidRedemption(incoming());
      
      allow update: if isSignedIn() && (
        resource.data.get('parentId', '') == request.auth.uid && 
        incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
        incoming().get('status', '') == 'completed'
      );
    }

    // --- Notifications ---
    match /notifications/{notificationId} {
      function canPostNotification(parentId) {
        return parentId == request.auth.uid || 
          exists(/databases/$(database)/documents/users/$(request.auth.uid));
      }

      allow read: if isSignedIn() && resource.data.get('parentId', '') == request.auth.uid;
      allow update: if isSignedIn() && resource.data.get('parentId', '') == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow create: if isSignedIn() && canPostNotification(incoming().get('parentId', ''));
    }
  }
}
