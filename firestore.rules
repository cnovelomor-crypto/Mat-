rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function emailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isParentOf(childId) {
      return isSignedIn() && getUserData(childId).parentId == request.auth.uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Rules ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == request.auth.uid 
          && data.role in ['parent', 'child']
          && data.displayName is string && data.displayName.size() <= 60
          && (data.role == 'parent' || data.parentId == null || (data.parentId is string && isValidId(data.parentId)))
          && (data.keys().hasAll(['uid', 'role', 'displayName']) && data.keys().size() <= 8);
      }

      allow get: if isOwner(userId) || isParentOf(userId);
      allow list: if isSignedIn() && (resource.data.uid == request.auth.uid || resource.data.parentId == request.auth.uid);
      
      allow create: if isOwner(userId) && isValidUser(incoming());
      
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        // Children can update points ONLY via transactional increments (hard to enforce strictly without functions, but we restrict fields)
        // For this demo, we allow specific fields
        (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'points', 'parentId', 'linkingCode']))
      ) || (
        // Parents can update child profiles (e.g. points, or assigning them)
        isParentOf(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['points', 'parentId'])
      );
    }

    // --- Exercise Results ---
    match /exerciseResults/{resultId} {
      function isValidResult(data) {
        return data.childId == request.auth.uid
          && data.category in ['sumas', 'restas', 'multiplicaciones', 'divisiones', 'figuras']
          && data.score is int && data.score >= 0
          && data.starsEarned is int && data.starsEarned >= 0
          && data.timestamp == request.time
          && data.keys().hasAll(['childId', 'category', 'score', 'totalQuestions', 'starsEarned', 'timestamp']);
      }

      allow read: if isOwner(existing().childId) || isParentOf(existing().childId);
      allow create: if isSignedIn() && isValidResult(incoming());
    }

    // --- Rewards ---
    match /rewards/{rewardId} {
      function isValidReward(data) {
        return data.title is string && data.title.size() <= 100
          && data.cost is int && data.cost >= 0
          && data.icon is string
          && (data.isCustom == false || (data.parentId == request.auth.uid))
          && data.keys().hasAll(['title', 'cost', 'icon']);
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidReward(incoming()) && (incoming().isCustom == true ? getUserData(request.auth.uid).role == 'parent' : false);
      allow update, delete: if isSignedIn() && existing().parentId == request.auth.uid;
    }

    // --- Redemptions ---
    match /redemptions/{redemptionId} {
      function isValidRedemption(data) {
        return data.childId == request.auth.uid
          && data.status == 'pending'
          && data.timestamp == request.time
          && data.parentId is string
          && data.keys().hasAll(['childId', 'rewardId', 'rewardTitle', 'status', 'timestamp', 'parentId']);
      }

      allow read: if isOwner(existing().childId) || isParentOf(existing().childId);
      
      allow create: if isSignedIn() && isValidRedemption(incoming());
      
      allow update: if (
        // Parent completes the redemption
        isParentOf(existing().childId) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
        incoming().status == 'completed'
      );
    }

    // --- Notifications ---
    match /notifications/{notificationId} {
      allow read: if isOwner(existing().parentId);
      allow update: if isOwner(existing().parentId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      // Creation usually happens via client side when child finishes exercise
      allow create: if isSignedIn(); // We could harden this to check child relationship
    }
  }
}
